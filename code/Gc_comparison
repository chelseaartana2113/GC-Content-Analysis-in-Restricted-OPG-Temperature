from scipy.stats import ttest_ind

meso_gc=df[df['Type']=='Mesophilic']['GC Content']
thermo_gc=df[df['Type']=='Thermophilic']['GC Content']
t_stat, p_value=ttest_ind(meso_gc,thermo_gc)

print('T-test statistic:',t_stat)
print('T-test p-value:',p_value)


from scipy.stats import pearsonr
