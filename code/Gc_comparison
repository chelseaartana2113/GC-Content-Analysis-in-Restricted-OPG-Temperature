results=[]
for name,file in organisms.items():
    genome_lines = []
    with open(file) as f:
        for line in f:
            if not line.startswith(">"):
                genome_lines.append(line.strip().upper())
    genome = ''.join(genome_lines)
    print(f'Organism analyzed:',name)
    A_count=genome.count('A')
    T_count=genome.count('T')
    G_count=genome.count('G')
    C_count=genome.count('C')
    total=A_count+T_count+C_count+G_count
    print('Total bases analyzed:',total)
    GC_content=round((G_count+C_count)/(total),3)
    A=round((A_count/total),3)
    T=round((T_count/total),3)
    G=round((G_count/total),3)
    C=round((C_count/total),3)
    print(f"""Nucleotide frequency:
    A: {A}
    T: {T}
    G: {G}
    C: {C}""")
    results.append({'Organism':name,'Genome length':total,
                    'GC Content':GC_content,
                    'Frequency of Adenine':A,
                    'Frequency of Thymine':T,
                    'Frequency of Guanine':G,
                    'Frequency of Cytosine':C
                    })
with open("results.txt", "w") as out:
    for r in results:
        out.write(str(r) + "\n")

df=pd.DataFrame(results)
